<!doctype html>
<html lang="en">
  <head>
    <title>{{ .ProjectName }} API Reference</title>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1" />
  </head>
  <body>
    <div id="app"></div>
    <script src={{ .ScalarScript }}></script>
    <script>
      Scalar.createApiReference('#app', {
        url: {{ .DocPath }},
      })
    </script>
  </body>
</html>